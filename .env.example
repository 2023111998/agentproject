# ============================================================================
# 校园电商/外卖智能服务平台 — Java 重构版 环境变量配置
# 复制此文件为 .env，按需修改
#   cp .env.example .env
# ============================================================================

# ── LLM / Agent 配置 ─────────────────────────────────────────────────────────
# API Key (阿里云 DashScope / OpenAI 兼容)
OPENAI_API_KEY=your-api-key-here
# API Base URL (默认为阿里云 DashScope 兼容端点)
OPENAI_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
# 对话模型 (qwen-plus / qwen-max / gpt-4 等)
CHAT_MODEL=qwen-plus
# RAG 政策检索 top-k 数量
POLICY_K=2

# ── 数据库配置 ───────────────────────────────────────────────────────────────
# MySQL 连接 (Docker Compose 用)
MYSQL_ROOT_PASSWORD=campus123
MYSQL_DATABASE=campus
MYSQL_URL=jdbc:mysql://mysql:3306/campus?useSSL=false&allowPublicKeyRetrieval=true&characterEncoding=UTF-8&useUnicode=true

# ── 服务端口配置 ─────────────────────────────────────────────────────────────
# (仅在非容器运行时需要修改)
SERVER_PORT=8000
ORDER_SERVICE_URL=http://localhost:8001
PRODUCT_SERVICE_URL=http://localhost:8002
LOGISTICS_SERVICE_URL=http://localhost:8003

# ── Docker Compose 配置 ──────────────────────────────────────────────────────
# 主应用副本数 (docker compose up --scale campus-server=N)
COMPOSE_SERVER_SCALE=2

# ── 评测 / 调试配置 ─────────────────────────────────────────────────────────
# 本地 Mock 模式 (true=不连接真实 LLM, 使用规则引擎)
USE_MOCK_LLM=true
# 评测迭代次数
EVAL_ITERATIONS=50

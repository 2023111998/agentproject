<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:camunda="http://camunda.org/schema/1.0/bpmn" id="Definitions_logistics_map" targetNamespace="http://bpmn.io/schema/bpmn" exporter="Camunda Modeler" exporterVersion="5.46.1">
  <bpmn:process id="logistics_map" name="物流地图查询流程" isExecutable="true">
    <bpmn:startEvent id="StartEvent" name="收到物流查询请求">
      <bpmn:outgoing>Flow_StartToQuery</bpmn:outgoing>
    </bpmn:startEvent>
    <bpmn:serviceTask id="Task_QueryLogistics" name="查询物流与路线数据" camunda:delegateExpression="${h_query_logistics}">
      <bpmn:incoming>Flow_StartToQuery</bpmn:incoming>
      <bpmn:outgoing>Flow_QueryToGateway</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:exclusiveGateway id="Gw_HasMapData" name="是否有地图数据?">
      <bpmn:incoming>Flow_QueryToGateway</bpmn:incoming>
      <bpmn:outgoing>Flow_YesMapData</bpmn:outgoing>
      <bpmn:outgoing>Flow_NoMapData</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:serviceTask id="Task_BuildRouteMap" name="构建配送路线地图" camunda:delegateExpression="${h_build_route_map}">
      <bpmn:incoming>Flow_YesMapData</bpmn:incoming>
      <bpmn:outgoing>Flow_BuildToEnd</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:endEvent id="EndEvent" name="返回物流信息">
      <bpmn:incoming>Flow_BuildToEnd</bpmn:incoming>
      <bpmn:incoming>Flow_NoMapData</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:sequenceFlow id="Flow_StartToQuery" sourceRef="StartEvent" targetRef="Task_QueryLogistics" />
    <bpmn:sequenceFlow id="Flow_QueryToGateway" sourceRef="Task_QueryLogistics" targetRef="Gw_HasMapData" />
    <bpmn:sequenceFlow id="Flow_YesMapData" name="是(有路线数据)" sourceRef="Gw_HasMapData" targetRef="Task_BuildRouteMap">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">${has_map_data == True}</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_NoMapData" name="否(无路线数据)" sourceRef="Gw_HasMapData" targetRef="EndEvent" />
    <bpmn:sequenceFlow id="Flow_BuildToEnd" sourceRef="Task_BuildRouteMap" targetRef="EndEvent" />
  </bpmn:process>
  <bpmndi:BPMNDiagram id="BPMNDiagram_1">
    <bpmndi:BPMNPlane id="BPMNPlane_1" bpmnElement="logistics_map">
      <bpmndi:BPMNShape id="Shape_StartEvent" bpmnElement="StartEvent">
        <dc:Bounds x="160" y="95" width="36" height="36" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_Task_QueryLogistics" bpmnElement="Task_QueryLogistics">
        <dc:Bounds x="250" y="73" width="120" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_Gw_HasMapData" bpmnElement="Gw_HasMapData" isMarkerVisible="true">
        <dc:Bounds x="430" y="88" width="50" height="50" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_Task_BuildRouteMap" bpmnElement="Task_BuildRouteMap">
        <dc:Bounds x="540" y="73" width="120" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_EndEvent" bpmnElement="EndEvent">
        <dc:Bounds x="720" y="95" width="36" height="36" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNEdge id="Edge_StartToQuery" bpmnElement="Flow_StartToQuery">
        <di:waypoint x="196" y="113" />
        <di:waypoint x="250" y="113" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Edge_QueryToGateway" bpmnElement="Flow_QueryToGateway">
        <di:waypoint x="370" y="113" />
        <di:waypoint x="430" y="113" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Edge_YesMapData" bpmnElement="Flow_YesMapData">
        <di:waypoint x="455" y="88" />
        <di:waypoint x="455" y="40" />
        <di:waypoint x="540" y="40" />
        <di:waypoint x="540" y="73" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="463" y="50" width="70" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Edge_NoMapData" bpmnElement="Flow_NoMapData">
        <di:waypoint x="455" y="138" />
        <di:waypoint x="455" y="200" />
        <di:waypoint x="738" y="200" />
        <di:waypoint x="738" y="131" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="520" y="196" width="70" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Edge_BuildToEnd" bpmnElement="Flow_BuildToEnd">
        <di:waypoint x="660" y="113" />
        <di:waypoint x="720" y="113" />
      </bpmndi:BPMNEdge>
    </bpmndi:BPMNPlane>
  </bpmndi:BPMNDiagram>
</bpmn:definitions>
